# claw-forge environment variables
# Copy to .env and fill in your values: cp .env.example .env
# Load before running: export $(cat .env | xargs)
# Or use direnv: https://direnv.net/

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Direct API key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY_1=sk-ant-...
ANTHROPIC_API_KEY_2=sk-ant-...   # optional second key for burst capacity

# OAuth token from `claude login` (auto-read from ~/.claude/.credentials.json)
# Set this only if you want to override the auto-read path
CLAUDE_OAUTH_TOKEN=

# ── Proxy / Anthropic-compat providers ───────────────────────────────────────
PROXY_1_KEY=
PROXY_API_KEY=

# ── Cloud providers ───────────────────────────────────────────────────────────
# AWS Bedrock — uses IAM/instance role by default; set these for explicit creds
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure AI Foundry
AZURE_API_KEY=
AZURE_ENDPOINT=https://your-resource.openai.azure.com

# Google Vertex AI — uses ADC by default (gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=

# ── Free-tier providers ───────────────────────────────────────────────────────
# Groq (https://console.groq.com/) — 14,400 req/day free
GROQ_API_KEY=gsk_...

# Cerebras (https://cloud.cerebras.ai/) — 1M tokens/day free
CEREBRAS_API_KEY=

# ── State service ─────────────────────────────────────────────────────────────
CLAW_FORGE_STATE_PORT=8888
CLAW_FORGE_STATE_HOST=127.0.0.1
CLAW_FORGE_DB_URL=sqlite:///claw_forge_state.db

# ── Kanban UI ─────────────────────────────────────────────────────────────────
CLAW_FORGE_UI_PORT=5173
