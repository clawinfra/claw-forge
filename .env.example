# claw-forge environment variables
# Copy to .env and fill in your values: cp .env.example .env
# Load before running: export $(cat .env | xargs)
# Or use direnv: https://direnv.net/

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Direct API key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY_1=sk-ant-...
ANTHROPIC_API_KEY_2=sk-ant-...   # optional second key for burst capacity

# OAuth token from `claude login` (auto-read from ~/.claude/.credentials.json)
# Set this only if you want to override the auto-read path
CLAUDE_OAUTH_TOKEN=

# ── Anthropic-compat proxies (x-api-key + /v1/messages format) ───────────────
# Proxy 1 (e.g. anthropic-proxy-1/claude-sonnet-4-6 style)
PROXY_1_API_KEY=
PROXY_1_BASE_URL=https://proxy1.example.com/v1
PROXY_1_MODEL=claude-sonnet-4-6

# Proxy 2
PROXY_2_API_KEY=
PROXY_2_BASE_URL=https://proxy2.example.com/v1
PROXY_2_MODEL=claude-sonnet-4-6

# Internal no-auth gateway (k8s sidecar, local proxy, etc.)
INTERNAL_GATEWAY_URL=http://localhost:8080/v1
INTERNAL_GATEWAY_MODEL=claude-sonnet-4-6

# ── OpenAI-compat proxy ───────────────────────────────────────────────────────
OPENAI_PROXY_BASE_URL=https://proxy.example.com/v1
OPENAI_PROXY_API_KEY=
OPENAI_PROXY_MODEL=claude-sonnet-4-6

# ── Cloud providers ───────────────────────────────────────────────────────────
# AWS Bedrock — uses IAM/instance role by default; set these for explicit creds
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure AI Foundry
AZURE_API_KEY=
AZURE_ENDPOINT=https://your-resource.openai.azure.com

# Google Vertex AI — uses ADC by default (gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# OLLAMA_API_KEY=   # optional, most local setups don't need this

# ── Free-tier providers ───────────────────────────────────────────────────────
# Groq (https://console.groq.com/) — 14,400 req/day free
GROQ_API_KEY=gsk_...

# Cerebras (https://cloud.cerebras.ai/) — 1M tokens/day free
CEREBRAS_API_KEY=

# ── State service ─────────────────────────────────────────────────────────────
CLAW_FORGE_STATE_PORT=8888
CLAW_FORGE_STATE_HOST=127.0.0.1
CLAW_FORGE_DB_URL=sqlite:///claw_forge_state.db

# ── Kanban UI ─────────────────────────────────────────────────────────────────
CLAW_FORGE_UI_PORT=5173
